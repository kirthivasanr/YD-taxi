/* Premium glassmorphic theme with gold accents */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap');

:root {
	color-scheme: dark;
	--text: #ffffff;
	--muted: rgba(255, 255, 255, 0.7);
	--gold: #FFD700;
	--gold-dark: #DAA520;
}

/* Layout max-width for all main content */
.main-content {
	max-width: 900px;
	margin: 0 auto;
	width: 100%;
}

html { 
	scroll-behavior: smooth; 
	overflow-x: hidden; 
}
* { 
	box-sizing: border-box; 
	margin: 0; 
	padding: 0; 
}

body {
	margin: 0;
	background: radial-gradient(ellipse at top, #1a1a1a 0%, #0a0a0a 50%);
	color: var(--text);
	font-family: 'Poppins', sans-serif;
	-webkit-font-smoothing: antialiased;
	min-height: 100vh;
	overflow-x: hidden;
}

.wrap, .main-content {
  margin-left: auto;
  margin-right: auto;
  width: 100%;
  box-sizing: border-box;
}

.gold { 
	color: var(--gold);
	text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
}
.muted { color: var(--muted); }
.small { font-size: 0.9rem; line-height: 1.6; }
.mt { margin-top: 16px; }
.mt-1 { margin-top: 8px; }
.mt-2 { margin-top: 12px; }
.text-center { text-align: center; }
.icon-xl { 
	font-size: 3.5rem;
	margin-bottom: 20px;
	filter: drop-shadow(0 0 15px rgba(255, 215, 0, 0.5));
	display: block;
	text-align: center;
}

/* Premium Navigation */
.nav {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 40px;
	position: sticky;
	top: 0;
	z-index: 50;
	background: rgba(10, 10, 10, 0.8);
	backdrop-filter: blur(20px) saturate(180%);
	border-bottom: 1px solid rgba(255, 215, 0, 0.2);
	padding: 16px 20px;
	border-radius: 0 0 24px 24px;
	box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
}
.brand {
	display: flex;
	align-items: center;
	gap: 28px;
}
.logo { 
	width: 64px;
	height: 64px;
	border-radius: 50%;
	box-shadow: 0 0 30px rgba(255, 215, 0, 0.5);
	object-fit: cover;
	border: 3px solid rgba(255, 215, 0, 0.4);
}
.brand-title { 
	font-weight: 900;
	font-size: 1.5rem;
	background: linear-gradient(135deg, #FFD700, #FFA500);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
}
.tag { 
	font-size: 0.7rem;
	letter-spacing: 0.15em;
	text-transform: uppercase;
	color: var(--muted);
	font-weight: 600;
}
.links { display: none; gap: 24px; align-items: center; }
.links a { 
	color: var(--text);
	text-decoration: none;
	opacity: 0.8;
	transition: all 0.3s ease;
	font-weight: 500;
}
.links a:hover { opacity: 1; color: var(--gold); }
.links a.active { 
	opacity: 1;
	color: var(--gold);
	position: relative;
}
.links a.active::after { 
	content: '';
	position: absolute;
	left: 0;
	right: 0;
	bottom: -8px;
	height: 3px;
	background: var(--gold);
	box-shadow: 0 0 10px var(--gold);
}
@media (min-width: 768px) { .links { display: flex; } }

/* Hero - Dramatic */
.hero { 
	position: relative;
	padding: 100px 0;
	min-height: 90vh;
	display: flex;
	align-items: center;
}
.hero h1 { 
	margin: 0 0 30px;
	font-size: clamp(3rem, 7vw, 5rem);
	font-weight: 900;
	line-height: 1.05;
	background: linear-gradient(135deg, #FFD700 0%, #FFA500 50%, #FFD700 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-size: 200% 100%;
	animation: shimmer 4s infinite;
	filter: drop-shadow(0 0 30px rgba(255, 215, 0, 0.4));
}
@keyframes shimmer {
	0%, 100% { background-position: 0% 50%; }
	50% { background-position: 100% 50%; }
}
.hero p {
	font-size: 1.35rem;
	line-height: 1.8;
	margin-bottom: 40px;
	color: var(--muted);
}
.hero .actions { display: flex; gap: 20px; margin: 50px 0 0; flex-wrap: wrap; }
.grid-2 { 
	display: grid;
	grid-template-columns: 1fr;
	gap: 32px;
	align-items: stretch;
	justify-items: center;
	width: 100%;
	box-sizing: border-box;
	padding-right: 12px;
	padding-left: 12px;
}
@media (min-width: 1025px) { 
	.grid-2 { 
		grid-template-columns: 1.4fr 0.6fr;
		gap: 48px;
		align-items: stretch;
		justify-items: center;
		padding-right: 32px;
		padding-left: 32px;
	}
}

/* Animated orbs - larger, more dramatic */
.bg-orb { 
	position: absolute;
	pointer-events: none;
	filter: blur(120px);
	opacity: 0.7;
	border-radius: 50%;
	animation: float 30s infinite ease-in-out;
}
@keyframes float {
	0%, 100% { transform: translate(0, 0) scale(1); }
	33% { transform: translate(50px, -50px) scale(1.2); }
	66% { transform: translate(-40px, 40px) scale(0.8); }
}
.bg-orb.orb1 { 
	width: 600px;
	height: 600px;
	left: -200px;
	top: -200px;
	background: radial-gradient(closest-side, rgba(255, 215, 0, 0.6), transparent 70%);
}
.bg-orb.orb2 { 
	width: 700px;
	height: 700px;
	right: -250px;
	top: 200px;
	background: radial-gradient(closest-side, rgba(255, 165, 0, 0.5), transparent 70%);
	animation-delay: -10s;
}
.bg-orb.orb3 { 
	width: 550px;
	height: 550px;
	left: 50%;
	bottom: -200px;
	background: radial-gradient(closest-side, rgba(218, 165, 32, 0.4), transparent 70%);
	animation-delay: -20s;
}

/* Premium buttons */
.btn { 
	display: inline-flex;
	align-items: center;
	justify-content: center;
	gap: 12px;
	padding: 18px 36px;
	border-radius: 16px;
	border: none;
	cursor: pointer;
	text-decoration: none;
	font-weight: 700;
	font-size: 15px;
	letter-spacing: 0.5px;
	transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	position: relative;
	overflow: hidden;
	text-transform: uppercase;
}
.btn::before {
	content: '';
	position: absolute;
	top: 50%;
	left: 50%;
	width: 0;
	height: 0;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.3);
	transform: translate(-50%, -50%);
	transition: width 0.6s, height 0.6s;
}
.btn:hover::before {
	width: 400px;
	height: 400px;
}
.btn:active { transform: scale(0.95); }
.btn:disabled {
	opacity: 0.5;
	cursor: not-allowed;
	pointer-events: none;
}
.btn.primary { 
	background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
	color: #000;
	box-shadow: 0 15px 40px rgba(255, 215, 0, 0.6);
}
.btn.primary:hover { 
	box-shadow: 0 20px 55px rgba(255, 215, 0, 0.8);
	transform: translateY(-4px);
}
.btn.ghost { 
	background: transparent;
	color: var(--gold);
	border: 2px solid var(--gold);
}
.btn.ghost:hover {
	background: rgba(255, 215, 0, 0.2);
	transform: translateY(-4px);
}
.btn.whatsapp {
	background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
	color: #fff;
	box-shadow: 0 15px 40px rgba(37, 211, 102, 0.6);
}
.btn.whatsapp:hover {
	box-shadow: 0 20px 55px rgba(37, 211, 102, 0.8);
	transform: translateY(-4px);
}
.w-50 { flex: 1; }

/* Glassmorphic cards */
.card { 
	background: rgba(255, 255, 255, 0.04);
	border: 1px solid rgba(255, 215, 0, 0.25);
	border-radius: 30px;
	padding: 32px;
	box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.15);
	backdrop-filter: blur(30px) saturate(200%);
	position: relative;
	overflow: hidden;
	transition: all 0.4s ease;
	width: 100%;
	max-width: 500px;
	margin: 0 auto;
	height: 100%;
	display: flex;
	flex-direction: column;
	margin: 0 8px;
}
.card::before {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	height: 2px;
	background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.card-title { 
	font-weight: 700;
	font-size: 1.2rem;
	margin-bottom: 12px;
}

/* Booking card - Premium Redesign */
.booking {
	width: 100%;
	max-width: 480px;
	margin: 0 auto;
	box-sizing: border-box;
	align-self: center;
	justify-self: center;
	display: flex;
	flex-direction: column;
	border-radius: 28px;
	padding: 32px 28px;
	background: linear-gradient(145deg, rgba(20, 20, 20, 0.95), rgba(10, 10, 10, 0.98));
	backdrop-filter: blur(40px) saturate(180%);
	box-shadow: 
		0 20px 60px rgba(0, 0, 0, 0.8),
		0 0 0 1px rgba(255, 215, 0, 0.3),
		inset 0 1px 0 rgba(255, 255, 255, 0.1);
	align-items: stretch;
	position: relative;
	overflow: visible;
}
.booking::before {
	content: '';
	position: absolute;
	inset: -2px;
	border-radius: 28px;
	padding: 2px;
	background: linear-gradient(145deg, var(--gold), transparent, var(--gold));
	-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
	-webkit-mask-composite: xor;
	mask-composite: exclude;
	opacity: 0.3;
	pointer-events: none;
}
.booking h3 { 
	margin: 0 0 24px;
	font-size: 1.6rem;
	text-align: center;
	font-weight: 800;
	letter-spacing: 0.5px;
}

/* Progress Bar */
.progress-container {
	width: 100%;
	height: 6px;
	background: rgba(255, 255, 255, 0.1);
	border-radius: 10px;
	overflow: hidden;
	margin-bottom: 8px;
	position: relative;
}
.progress-bar {
	height: 100%;
	background: linear-gradient(90deg, var(--gold), var(--gold-dark));
	border-radius: 10px;
	transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	box-shadow: 0 0 15px rgba(255, 215, 0, 0.6);
	position: relative;
}
.progress-bar::after {
	content: '';
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
	animation: shimmer-progress 2s infinite;
}
@keyframes shimmer-progress {
	0% { transform: translateX(-100%); }
	100% { transform: translateX(100%); }
}
.progress-text {
	text-align: center;
	font-size: 0.75rem;
	color: var(--muted);
	margin-bottom: 20px;
	font-weight: 600;
}

/* Segment Control - Enhanced */
.seg { 
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 12px;
	margin-bottom: 28px;
	width: 100%;
	box-sizing: border-box;
	background: rgba(0, 0, 0, 0.4);
	padding: 6px;
	border-radius: 16px;
	border: 1px solid rgba(255, 255, 255, 0.1);
}
.seg-btn { 
	padding: 14px 20px;
	border-radius: 12px;
	width: 100%;
	text-align: center;
	background: transparent;
	border: none;
	color: var(--muted);
	font-weight: 600;
	font-size: 14px;
	cursor: pointer;
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 8px;
	position: relative;
	overflow: hidden;
	font-family: 'Poppins', sans-serif;
}
.seg-btn::before {
	content: '';
	position: absolute;
	inset: 0;
	background: linear-gradient(135deg, var(--gold), var(--gold-dark));
	opacity: 0;
	transition: opacity 0.3s ease;
	border-radius: 12px;
}
.seg-btn.active {
	color: #000;
	font-weight: 700;
	transform: scale(1.02);
}
.seg-btn.active::before {
	opacity: 1;
}
.seg-btn:hover:not(.active) {
	background: rgba(255, 255, 255, 0.05);
	color: var(--text);
}
.seg-icon {
	font-size: 16px;
	position: relative;
	z-index: 1;
}
.seg-btn span {
	position: relative;
	z-index: 1;
}

/* Form Sections */
.form { 
	display: flex;
	flex-direction: column;
	gap: 24px;
	width: 100%;
	box-sizing: border-box;
}
.form-section {
	background: rgba(255, 255, 255, 0.02);
	border: 1px solid rgba(255, 255, 255, 0.08);
	border-radius: 20px;
	padding: 20px;
	transition: all 0.3s ease;
}
.form-section:hover {
	border-color: rgba(255, 215, 0, 0.2);
	background: rgba(255, 255, 255, 0.03);
}
.section-title {
	font-weight: 700;
	font-size: 0.95rem;
	color: var(--gold);
	margin-bottom: 16px;
	display: flex;
	align-items: center;
	gap: 10px;
	text-transform: uppercase;
	letter-spacing: 0.5px;
}
.section-icon {
	font-size: 20px;
	filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.4));
}

/* Field Groups */
.field-group {
	width: 100%;
	box-sizing: border-box;
	position: relative;
	margin-bottom: 8px;
}

/* Floating Labels */
.floating-label {
	position: absolute;
	left: 18px;
	top: 50%;
	transform: translateY(-50%);
	color: var(--muted);
	font-size: 15px;
	pointer-events: none;
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.8) 50%);
	padding: 0 6px;
	display: flex;
	align-items: center;
	gap: 6px;
	font-weight: 500;
	z-index: 1;
}
.floating-label.active {
	top: 0;
	font-size: 12px;
	color: var(--gold);
	font-weight: 600;
}
.label-icon {
	font-size: 14px;
	filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.3));
}

/* Form Inputs - Enhanced */
.form input, .form select, .form textarea { 
	width: 100%;
	padding: 18px 16px;
	border-radius: 14px;
	border: 2px solid rgba(255, 255, 255, 0.15);
	background: rgba(0, 0, 0, 0.5);
	color: var(--text);
	outline: none;
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	font-family: 'Poppins', sans-serif;
	font-size: 15px;
	box-sizing: border-box;
	font-weight: 500;
}
.form input:focus, .form select:focus, .form textarea:focus {
	border-color: var(--gold);
	background: rgba(0, 0, 0, 0.7);
	box-shadow: 
		0 0 0 4px rgba(255, 215, 0, 0.12),
		0 8px 24px rgba(255, 215, 0, 0.15);
	transform: translateY(-1px);
}
.form input:focus + .floating-label,
.form select:focus + .floating-label,
.form textarea:focus + .floating-label {
	color: var(--gold);
}
.form textarea.text { 
	min-height: 80px;
	resize: vertical;
	padding-top: 16px;
}

/* Phone Input Group - Enhanced */
.phone-input-group {
	display: flex;
	gap: 10px;
	width: 100%;
}
.country-code-select {
	width: 115px;
	padding: 18px 12px;
	border-radius: 14px;
	border: 2px solid rgba(255, 255, 255, 0.15);
	background: rgba(0, 0, 0, 0.5);
	color: var(--text);
	outline: none;
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	font-family: 'Poppins', sans-serif;
	font-size: 15px;
	box-sizing: border-box;
	text-align: center;
	cursor: pointer;
	font-weight: 600;
}
.country-code-select:focus {
	border-color: var(--gold);
	background: rgba(0, 0, 0, 0.7);
	box-shadow: 
		0 0 0 4px rgba(255, 215, 0, 0.12),
		0 8px 24px rgba(255, 215, 0, 0.15);
}
.phone-input {
	flex: 1;
}
.char-counter {
	text-align: right;
	font-size: 0.7rem;
	color: var(--muted);
	margin-top: 4px;
	font-weight: 600;
}

/* Date/Time Groups */
.date-time-group {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 12px;
	margin-bottom: 12px;
}
.journey-label {
	font-size: 0.85rem;
	color: var(--gold);
	font-weight: 600;
	margin-bottom: 8px;
	margin-top: 12px;
	text-transform: uppercase;
	letter-spacing: 0.5px;
}

/* Vehicle & Details Groups */
.vehicle-distance-group,
.passengers-luggage-group {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 12px;
	margin-bottom: 12px;
}

/* Error Messages - Enhanced */
.error-msg {
	display: flex;
	align-items: center;
	gap: 6px;
	color: #ff6b6b;
	font-size: 0.75rem;
	margin-top: 6px;
	margin-left: 4px;
	font-weight: 600;
	animation: shake 0.4s ease;
}
@keyframes shake {
	0%, 100% { transform: translateX(0); }
	25% { transform: translateX(-5px); }
	75% { transform: translateX(5px); }
}
.form input.error, .form select.error {
	border-color: #ff6b6b;
	background: rgba(255, 107, 107, 0.08);
	animation: error-pulse 0.5s ease;
}
@keyframes error-pulse {
	0%, 100% { transform: scale(1); }
	50% { transform: scale(0.98); }
}
.form input.error:focus, .form select.error:focus {
	border-color: #ff6b6b;
	box-shadow: 
		0 0 0 4px rgba(255, 107, 107, 0.15),
		0 8px 24px rgba(255, 107, 107, 0.2);
}

/* Action Buttons */
.action-buttons {
	display: grid;
	grid-template-columns: 1fr;
	gap: 12px;
	margin-top: 8px;
}
.btn-estimate,
.btn-whatsapp {
	width: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 10px;
	padding: 18px 28px;
	font-size: 16px;
	font-weight: 700;
	border-radius: 16px;
	text-transform: uppercase;
	letter-spacing: 0.5px;
}
.btn-icon {
	font-size: 20px;
	filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
}

/* Estimate Box - Redesigned */
.estimate-box {
	background: linear-gradient(145deg, rgba(255, 215, 0, 0.08), rgba(255, 165, 0, 0.05));
	border: 2px solid rgba(255, 215, 0, 0.4);
	border-radius: 20px;
	padding: 24px;
	margin-top: 20px;
}
.estimate-header {
	display: flex;
	align-items: center;
	gap: 12px;
	font-size: 1.1rem;
	font-weight: 700;
	color: var(--gold);
	margin-bottom: 20px;
	padding-bottom: 12px;
	border-bottom: 1px solid rgba(255, 215, 0, 0.2);
}
.estimate-icon {
	font-size: 24px;
	filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
}
.estimate-row {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 12px 0;
	font-size: 0.95rem;
	border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.estimate-row:last-of-type {
	border-bottom: none;
}
.estimate-value {
	font-weight: 700;
	color: var(--gold);
	font-size: 1rem;
}
.estimate-divider {
	height: 2px;
	background: linear-gradient(90deg, transparent, var(--gold), transparent);
	margin: 16px 0;
}
.estimate-total {
	font-size: 1.15rem;
	font-weight: 800;
	padding: 16px 0;
	color: var(--gold);
}
.estimate-total .estimate-value {
	font-size: 1.3rem;
	text-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
}
.estimate-note {
	background: rgba(255, 215, 0, 0.08);
	border: 1px solid rgba(255, 215, 0, 0.2);
	border-radius: 12px;
	padding: 12px;
	margin-top: 16px;
	font-size: 0.85rem;
	color: var(--muted);
	display: flex;
	align-items: center;
	gap: 8px;
	font-style: italic;
}
.note-icon {
	font-size: 16px;
}
.estimate-actions {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 12px;
	margin-top: 20px;
}

/* Success Box */
.success-box {
	background: linear-gradient(145deg, rgba(37, 211, 102, 0.12), rgba(18, 140, 126, 0.08));
	border: 2px solid rgba(37, 211, 102, 0.5);
	border-radius: 20px;
	padding: 28px;
	text-align: center;
	margin-top: 20px;
}
.success-icon {
	width: 64px;
	height: 64px;
	background: linear-gradient(135deg, #25D366, #128C7E);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 36px;
	color: #fff;
	margin: 0 auto 20px;
	box-shadow: 
		0 15px 40px rgba(37, 211, 102, 0.4),
		0 0 0 8px rgba(37, 211, 102, 0.1);
	animation: success-pop 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}
@keyframes success-pop {
	0% { transform: scale(0); }
	50% { transform: scale(1.1); }
	100% { transform: scale(1); }
}
.success-title {
	font-size: 1.3rem;
	font-weight: 800;
	color: #25D366;
	margin-bottom: 16px;
}
.booking-ref {
	background: rgba(37, 211, 102, 0.1);
	border: 1px solid rgba(37, 211, 102, 0.3);
	border-radius: 12px;
	padding: 16px;
	margin: 16px 0;
	display: flex;
	flex-direction: column;
	gap: 8px;
}
.ref-label {
	font-size: 0.85rem;
	color: var(--muted);
	font-weight: 600;
}
.ref-value {
	font-size: 1.4rem;
	font-weight: 800;
	color: #25D366;
	letter-spacing: 2px;
	font-family: 'Courier New', monospace;
}
.success-message {
	color: var(--muted);
	font-size: 0.95rem;
	line-height: 1.6;
}

/* Spinner for loading state */
.spinner {
	width: 16px;
	height: 16px;
	border: 3px solid rgba(0, 0, 0, 0.3);
	border-top-color: #000;
	border-radius: 50%;
	animation: spin 0.6s linear infinite;
	display: inline-block;
}
@keyframes spin {
	to { transform: rotate(360deg); }
}

/* Slide-in animation */
.slide-in {
	animation: slideIn 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
@keyframes slideIn {
	from {
		opacity: 0;
		transform: translateY(20px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

/* Form Footer */
.form-footer {
	text-align: center;
	font-size: 0.8rem;
	color: var(--muted);
	margin-top: 16px;
	padding: 16px;
	background: rgba(255, 255, 255, 0.02);
	border-radius: 12px;
	border: 1px solid rgba(255, 255, 255, 0.05);
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 8px;
	line-height: 1.5;
}
.footer-icon {
	font-size: 16px;
	filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.3));
}

/* Responsive Updates */
@media (max-width: 768px) {
	.booking {
		max-width: 96vw;
		padding: 24px 20px;
		border-radius: 24px;
	}
	.date-time-group,
	.vehicle-distance-group,
	.passengers-luggage-group {
		grid-template-columns: 1fr;
		gap: 16px;
	}
	.estimate-actions {
		grid-template-columns: 1fr;
	}
	.seg {
		gap: 8px;
	}
}

/* Sections */
.section { 
	margin-top: 100px;
	scroll-margin-top: 100px;
	padding-bottom: 32px;
}

.section > h2, .section > h3 {
	margin-bottom: 36px !important;
}

.section {
	/* Add more vertical space between sections */
	margin-bottom: 32px;
}
.section h2,
.section h3 { 
	font-size: clamp(2rem, 4vw, 2.8rem);
	font-weight: 900;
	margin-bottom: 50px;
	text-align: center;
	width: 100%;
}
.grid-3 { 
	display: grid;
	grid-template-columns: 1fr;
	gap: 30px;
	width: 100%;
	box-sizing: border-box;
}
@media (min-width: 769px) and (max-width: 1024px) {
	.grid-3 {
		grid-template-columns: repeat(2, 1fr);
		gap: 25px;
	}
}
@media (min-width: 1025px) { 
	.grid-3 { 
		grid-template-columns: repeat(3, 1fr);
		gap: 35px;
	}
}

/* Chips */
.chips { 
	display: flex;
	flex-wrap: wrap;
	gap: 14px;
	justify-content: center;
	width: 100%;
	max-width: 1000px;
	margin: 0 auto;
}
.chip { 
	padding: 12px 24px;
	border-radius: 999px;
	border: 1px solid rgba(255, 215, 0, 0.4);
	background: rgba(255, 215, 0, 0.1);
	transition: all 0.3s ease;
	font-weight: 600;
	text-align: center;
}
.chip:hover { 
	transform: translateY(-5px);
	background: rgba(255, 215, 0, 0.2);
	box-shadow: 0 10px 25px rgba(255, 215, 0, 0.4);
}

/* Testimonials */
.testimonial { 
	text-align: center;
	padding: 30px;
	max-width: 800px;
	margin: 0 auto;
}
.testimonial .quote { 
	font-size: 1.15rem;
	line-height: 1.8;
	font-style: italic;
}
.testimonial .by { 
	margin-top: 20px;
	font-weight: 700;
	color: var(--gold);
}
.dots { 
	display: flex;
	justify-content: center;
	gap: 12px;
	margin-top: 24px;
}
.dot { 
	width: 12px;
	height: 12px;
	border-radius: 50%;
	background: rgba(255, 215, 0, 0.4);
	cursor: pointer;
	transition: all 0.3s ease;
}
.dot.active { 
	transform: scale(1.5);
	background: var(--gold);
	box-shadow: 0 0 15px var(--gold);
}

/* Tables */
.tbl { 
	width: 100%;
	border-collapse: collapse;
	margin-top: 20px;
}
.tbl th, .tbl td { 
	padding: 14px 12px;
	border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	text-align: left;
}
.tbl thead th { 
	color: var(--gold);
	font-weight: 700;
	text-transform: uppercase;
	font-size: 0.85rem;
	letter-spacing: 0.05em;
}
.tbl tbody tr:hover {
	background: rgba(255, 215, 0, 0.05);
}

/* Footer */
.footer { 
	margin-top: 120px;
	padding-top: 50px;
	border-top: 1px solid rgba(255, 255, 255, 0.1);
	text-align: center;
}
.copyright { 
	text-align: center;
	color: var(--muted);
	font-size: 0.85rem;
	margin-top: 24px;
	opacity: 0.6;
}

/* Reveal animations */
.reveal { 
	opacity: 0;
	transform: translateY(40px) scale(0.9);
	filter: blur(5px);
	transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
}
.reveal.in { 
	opacity: 1;
	transform: translateY(0) scale(1);
	filter: blur(0);
}

/* Back to top */
.to-top { 
	position: fixed;
	right: 24px;
	bottom: 24px;
	width: 56px;
	height: 56px;
	border-radius: 16px;
	display: grid;
	place-content: center;
	text-decoration: none;
	background: linear-gradient(135deg, #FFD700, #FFA500);
	color: #000;
	box-shadow: 0 12px 40px rgba(255, 215, 0, 0.6);
	transition: all 0.3s ease;
	font-size: 28px;
	font-weight: 900;
}
.to-top:hover { 
	transform: translateY(-6px);
	box-shadow: 0 18px 50px rgba(255, 215, 0, 0.8);
}

/* CTA bar */
.cta-bar { 
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0;
	z-index: 60;
	background: rgba(10, 10, 10, 0.95);
	backdrop-filter: blur(25px);
	border-top: 1px solid rgba(255, 215, 0, 0.3);
	display: grid;
	grid-template-columns: 1fr 1fr 1fr;
	gap: 12px;
	padding: 14px 18px;
	box-shadow: 0 -12px 40px rgba(0, 0, 0, 0.6);
}
.cta-bar .btn { padding: 14px; font-size: 13px; }
@media (min-width: 768px) { .cta-bar { display: none; } }

/* WhatsApp FAB */
.fab-whatsapp { 
	position: fixed;
	right: 24px;
	bottom: 110px;
	width: 64px;
	height: 64px;
	border-radius: 50%;
	background: linear-gradient(135deg, #25D366, #128C7E);
	color: #fff;
	display: grid;
	place-content: center;
	font-size: 32px;
	box-shadow: 0 15px 40px rgba(37, 211, 102, 0.7);
	transition: all 0.3s ease;
	animation: pulse 2s infinite;
}
@keyframes pulse {
	0%, 100% { transform: scale(1); }
	50% { transform: scale(1.08); }
}
.fab-whatsapp:hover {
	transform: scale(1.15);
	box-shadow: 0 20px 50px rgba(37, 211, 102, 0.9);
}
@media (min-width: 768px) { .fab-whatsapp { bottom: 24px; } }

/* Mobile menu */
.menu-toggle { 
	width: 50px;
	height: 50px;
	border-radius: 14px;
	border: 1px solid rgba(255, 255, 255, 0.3);
	background: rgba(255, 215, 0, 0.15);
	color: var(--gold);
	font-size: 26px;
	cursor: pointer;
	display: flex;
	align-items: center;
	justify-content: center;
	line-height: 1;
	padding: 0;
	box-shadow: 0 4px 16px rgba(0,0,0,0.25);
}
@media (min-width: 768px) { .menu-toggle { display: none; } }
.links.mobile { 
	display: grid;
	gap: 14px;
	padding: 20px;
	border: 1px solid rgba(255, 215, 0, 0.3);
	border-radius: 20px;
	background: rgba(10, 10, 10, 0.98);
	backdrop-filter: blur(30px);
	position: absolute;
	right: 16px;
	top: 90px;
	box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
}

/* Responsive */
@media (max-width: 480px) {
	.logo { width: 56px; height: 56px; }
	.btn { width: 100%; }
	.hero { padding: 60px 0; }
	.section { margin-top: 60px; }
	.section h2,
	.section h3 {
		font-size: 1.8rem;
		margin-bottom: 30px;
	}
	.card {
		padding: 24px;
	}
	.hero h1 {
		font-size: 2.2rem;
	}
	.hero p {
		font-size: 1.1rem;
	}
	.wrap {
		padding: 30px 16px 140px;
	}
}

/* Tablet specific fixes */
@media (min-width: 481px) and (max-width: 1024px) {
	.wrap {
		padding: 40px 24px 120px;
		max-width: 100%;
	}
	.grid-2 {
		grid-template-columns: 1fr;
		gap: 40px;
	}
	.hero {
		padding: 80px 0;
	}
	.booking {
		max-width: 600px;
		margin: 0 auto;
	}
	.card {
		padding: 28px;
	}
	.section h2,
	.section h3 {
		font-size: 2.2rem;
	}
}

@media (max-width: 768px) {
	.grid-2 {
		grid-template-columns: 1fr;
		gap: 40px;
	}
	.grid-3 {
		grid-template-columns: 1fr;
		gap: 20px;
	}
}

/* Hover effects */
.hoverable { transition: all 0.4s ease; }
.hoverable:hover { 
	transform: translateY(-10px);
	box-shadow: 0 35px 90px rgba(0, 0, 0, 0.7);
	border-color: rgba(255, 215, 0, 0.5);
}

/* FAQ Accordion */
.faq-container {
	max-width: 900px;
	margin: 0 auto;
	width: 100%;
	box-sizing: border-box;
}
.faq-item {
	background: rgba(255, 255, 255, 0.04);
	border: 1px solid rgba(255, 215, 0, 0.25);
	border-radius: 20px;
	margin-bottom: 16px;
	overflow: hidden;
	cursor: pointer;
	transition: all 0.3s ease;
	box-sizing: border-box;
}
.faq-item:hover {
	border-color: rgba(255, 215, 0, 0.5);
	box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
}
.faq-item.open {
	border-color: var(--gold);
	box-shadow: 0 15px 40px rgba(255, 215, 0, 0.3);
}
.faq-question {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 20px 24px;
	font-weight: 600;
	font-size: 1.05rem;
	color: var(--text);
	gap: 16px;
}
.faq-icon {
	font-size: 28px;
	color: var(--gold);
	font-weight: 700;
	min-width: 30px;
	text-align: center;
	transition: transform 0.3s ease;
}
.faq-item.open .faq-icon {
	transform: rotate(180deg);
}
.faq-answer {
	padding: 0 24px 20px 24px;
	color: var(--muted);
	line-height: 1.7;
	font-size: 0.95rem;
}

/* Map container */
.map-container {
	max-width: 100%;
	width: 100%;
	box-sizing: border-box;
}

@media (max-width: 767px) { .wrap { padding-bottom: 140px; } }
.text-center { text-align: center; }
.icon-xl { font-size: 3.5rem; margin-bottom: 20px; filter: drop-shadow(0 0 15px rgba(255, 215, 0, 0.5)); }
