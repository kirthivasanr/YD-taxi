# Static site reference values for YD TAXI
# Browsers cannot read .env files directly without a build step.
# Copy these values into ./js/config.js before deployment.

YD_TAXI_BUSINESS_NAME=YD TAXI
YD_TAXI_BASE_CITY=Chennai
YD_TAXI_SITE_URL=https://your-domain.example
YD_TAXI_WHATSAPP_NUMBER=919080609081
YD_TAXI_PHONE_NUMBER=+919080609081
YD_TAXI_CONTACT_EMAIL=support@ydtaxi.example
YD_TAXI_GOOGLE_MAPS_API_KEY=
YD_TAXI_ENABLE_MAPS_AUTOCOMPLETE=false
